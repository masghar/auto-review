{
  "manifest_version": 3,
  "name": "GMB Review AI",
  "version": "6.1.0",
  "description": "Auto-reply to Google Business Profile reviews using Gemini AI.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://business.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [{
    "matches": ["https://business.google.com/*"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GMB Review AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
